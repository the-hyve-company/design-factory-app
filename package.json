{
  "name": "design-factory",
  "version": "1.1.1",
  "private": true,
  "license": "Apache-2.0",
  "description": "A local-first AI design workspace for turning prompts into editable HTML artifacts.",
  "homepage": "https://github.com/the-hyve-company/design-factory#readme",
  "bugs": {
    "url": "https://github.com/the-hyve-company/design-factory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-hyve-company/design-factory.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "bridge": "npm start -w @df/daemon",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:web:legacy": "npm start -w @df/daemon & vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:audit:md": "node scripts/i18n-audit.mjs --md",
    "i18n:audit:json": "node scripts/i18n-audit.mjs --json",
    "i18n:baseline": "node scripts/i18n-audit.mjs --baseline",
    "smoke:daemon": "node scripts/daemon-smoke.mjs",
    "smoke:public-files": "node scripts/public-files-smoke.mjs",
    "test:e2e:providers": "node scripts/e2e-providers.mjs",
    "test:e2e:leak-regression": "node scripts/e2e-leak-regression.mjs",
    "test:e2e:modals": "node scripts/validate-modals.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.2",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.5",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "typescript": "^5.5.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
